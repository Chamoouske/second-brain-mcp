# Absolute path to the local second brain vault managed by the MCP server.
SECOND_BRAIN_ROOT=C:\Users\ajaxl\Documents\my-second-brain

# Number of days rejected wiki drafts stay in wiki/rejected before purge_rejected can delete them.
SECOND_BRAIN_REJECTED_RETENTION_DAYS=30

# Transport mode: stdio for local MCP clients, http for Streamable HTTP.
MCP_TRANSPORT=stdio

# HTTP transport settings. Used when MCP_TRANSPORT=http.
HOST=127.0.0.1
PORT=3000
MCP_HTTP_PATH=/mcp

# Docker Compose host port.
SECOND_BRAIN_MCP_PORT=3000
