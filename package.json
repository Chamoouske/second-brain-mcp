{
  "name": "second-brain-mcp",
  "version": "0.1.0",
  "description": "Local-first MCP server for managing a file-based second brain.",
  "type": "module",
  "bin": {
    "second-brain-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "start:http": "node -e \"process.env.MCP_TRANSPORT='http'; import('./dist/server.js').then((m)=>m.main())\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "mutate": "stryker run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "express": "^5.2.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.0.1",
    "@stryker-mutator/vitest-runner": "^9.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.34",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
